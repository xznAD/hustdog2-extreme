<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="transmission.xacro"/>

    <xacro:macro name="leg" params="name mirror mirror_dae front_hind front_hind_dae">

        <joint name="${name}_hip_joint" type="revolute">
            <origin rpy="0 0 0" xyz="${front_hind * hip_offset_x} ${mirror * hip_offset_y} ${hip_offset_z}"/>
            <parent link="trunk"/>
            <child link="${name}_hip"/>
            <axis xyz="1 0 0"/>
            <dynamics damping="${damping}" friction="${friction}"/>
            <limit lower="${hip_lower}" upper="${hip_upper}" effort="${hip_effort}" velocity="${hip_velocity}"/>
        </joint>

        <link name="${name}_hip">
            <visual>
                <xacro:if value="${name == 'RR'}">
                    <origin rpy="${PI} 0 0" xyz="0 0 0"/>
                </xacro:if>
                <xacro:unless value="${name == 'RR'}">
                    <origin rpy="0 0 0" xyz="0 0 0"/>
                </xacro:unless>
                <geometry>
                    <mesh filename="../meshes/${name}_hip.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin rpy="0 ${PI/2.0} 0" xyz="0 0 0"/>
                <geometry>
                    <cylinder length="${hip_length}" radius="${hip_radius}"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="${hip_com_x} ${-mirror*hip_com_y} ${hip_com_z}"/>
                <mass value="${hip_mass}"/>
                <inertia ixx="${hip_ixx}" ixy="${hip_ixy}" ixz="${hip_ixz}" iyy="${hip_iyy}" iyz="${hip_iyz}" izz="${hip_izz}"/>
            </inertial>
        </link>

        <joint name="${name}_thigh_joint" type="revolute">
            <origin rpy="0 0 0" xyz="${hip_link_length} 0 0"/>
            <parent link="${name}_hip"/>
            <child link="${name}_thigh"/>
            <axis xyz="0 1 0"/>
            <dynamics damping="${damping}" friction="${friction}"/>
            <limit lower="${thigh_lower}" upper="${thigh_upper}" effort="${thigh_effort}" velocity="${thigh_velocity}"/>
        </joint>

        <link name="${name}_thigh">
            <visual>
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <geometry>
                    <mesh filename="../meshes/${name}_thigh.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin rpy="${PI/2.0} 0 0" xyz="${thigh_com_x} ${-mirror*thigh_com_y} ${thigh_com_z+0.065}"/>
                <geometry>
                     <cylinder length="${thigh_shoulder_length}" radius="${thigh_shoulder_radius}"/>
                </geometry>
            </collision>
            <collision>
                <origin rpy="0 0 0" xyz="${thigh_com_x} ${-mirror*thigh_com_y} ${thigh_com_z}"/>
                <geometry>
                    <box size="${thigh_width} ${thigh_height} ${calf_link_length}"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="${thigh_com_x} ${-mirror*thigh_com_y} ${thigh_com_z}"/>
                <mass value="${thigh_mass}"/>
                <inertia ixx="${thigh_ixx}" ixy="${thigh_ixy}" ixz="${thigh_ixz}" iyy="${thigh_iyy}" iyz="${thigh_iyz}" izz="${thigh_izz}"/>
            </inertial>
        </link>

        <joint name="${name}_calf_joint" type="revolute">
            <origin rpy="0 0 0" xyz="0 0 -0.22"/>
            <parent link="${name}_thigh"/>
            <child link="${name}_calf"/>
            <axis xyz="0 1 0"/>
            <dynamics damping="${damping}" friction="${friction}"/>
            <limit lower="${calf_lower}" upper="${calf_upper}" effort="${calf_effort}" velocity="${calf_velocity}"/>
        </joint>

        <link name="${name}_calf">
            <visual>
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <geometry>
                    <mesh filename="../meshes/${name}_calf.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin rpy="0 0 0" xyz="${calf_com_x} ${-mirror*calf_com_y} ${calf_com_z}"/>
                <geometry>
                    <box size="${calf_width} ${calf_height} ${calf_length}"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="${calf_com_x} ${-mirror*calf_com_y} ${calf_com_z}"/>
                <mass value="${calf_mass}"/>
                <inertia ixx="${calf_ixx}" ixy="${calf_ixy}" ixz="${calf_ixz}" iyy="${calf_iyy}" iyz="${calf_iyz}" izz="${calf_izz}"/>
            </inertial>
        </link>

        <joint name="${name}_foot_fixed" type="fixed">
            <origin rpy="0 0 0" xyz="-0.029484 0 -0.19799"/>
            <parent link="${name}_calf"/>
            <child link="${name}_foot"/>
        </joint>

        <link name="${name}_foot">
            <visual>
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <geometry>
                    <mesh filename="../meshes/${name}_foot.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin rpy="0 0 0" xyz="-0.004 ${mirror * 0.085} -0.003"/> 
                <geometry>
                    <sphere radius="${foot_radius}"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="${foot_com_x} ${-mirror*foot_com_y} ${foot_com_z}"/>
                <mass value="${foot_mass}"/>
                <inertia ixx="${foot_ixx}" ixy="${foot_ixy}" ixz="${foot_ixz}" iyy="${foot_iyy}" iyz="${foot_iyz}" izz="${foot_izz}"/>
            </inertial>
        </link>

        <xacro:leg_transmission name="${name}"/>
    </xacro:macro>
</robot>
